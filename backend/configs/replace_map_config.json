{
  "schema_version": "1.0",
  "name": "光明眼镜案件默认替换配置",
  "description": "将 Defandent、DemandLetter 和 logical 的抽取结果转换为 Word 替换所需的 replace_map。",
  "on_missing": "empty",
  "mappings": {
    "[--需要替换的被告--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["企业名称", 0, "value"],
      "default": "",
      "required": true,
      "editable": true,
      "description": "从企业报告中读取被告名称"
    },
    "[--需要替换的被告2--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["企业名称", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "模板别名：第二处被告名称"
    },
    "[--需要替换的统一社会信用代码--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["统一社会信用代码", 0, "value"],
      "default": "",
      "required": true,
      "editable": true,
      "description": "从企业报告中读取统一社会信用代码"
    },
    "[--需要替换的住所--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["住所", 0, "value"],
      "default": "",
      "required": true,
      "editable": true,
      "description": "从企业报告中读取住所"
    },
    "[--需要替换的住所2--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["住所", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "模板别名：第二处住所"
    },
    "[--需要替换的成立日期--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["成立日期", 0, "value"],
      "default": "",
      "required": true,
      "editable": true,
      "description": "从企业报告中读取成立日期"
    },
    "[--需要替换的成立日期2--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["成立日期", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "模板别名：第二处成立日期"
    },
    "[--需要替换的经营范围--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["经营范围", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "从企业报告中读取经营范围"
    },
    "[--需要替换的法定代表人--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["法定代表人", 0, "value"],
      "default": "",
      "required": true,
      "editable": true,
      "description": "从企业报告中读取法定代表人"
    },
    "[--需要替换的联系电话--]": {
      "mode": "path",
      "source": "Defandent",
      "path": ["联系电话", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "从企业报告中读取联系电话，缺失时留空"
    },
    "[--需要替换的侵权事实--]": {
      "mode": "path",
      "source": "DemandLetter",
      "path": ["侵权事实", 0, "value"],
      "default": "",
      "required": true,
      "editable": true,
      "description": "从律师函抽取结果中读取侵权事实"
    },
    "[--需要替换的侵权事实1--]": {
      "mode": "path",
      "source": "DemandLetter",
      "path": ["侵权事实", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "模板别名：第二处侵权事实"
    },
    "[--需要替换的律师函日期--]": {
      "mode": "path",
      "source": "DemandLetter",
      "path": ["律师函日期", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "从律师函抽取结果中读取律师函日期"
    },
    "[--需要替换的法院名称--]": {
      "mode": "literal",
      "value": "天津市和平区人民法院",
      "default": "",
      "required": false,
      "editable": true,
      "description": "固定法院名称示例"
    },
    "[--需要替换的诉请金额--]": {
      "mode": "literal",
      "value": "10",
      "default": "10",
      "required": false,
      "editable": true,
      "description": "默认诉请金额（万元）"
    },
    "[--需要替换的侵权公司信息--]": {
      "mode": "template",
      "template": "被告{{name}}，成立于{{date}}，住所地为{{address}}，经营范围包括{{scope}}。",
      "vars": {
        "name": {
          "mode": "path",
          "source": "Defandent",
          "path": ["企业名称", 0, "value"],
          "default": ""
        },
        "date": {
          "mode": "path",
          "source": "Defandent",
          "path": ["成立日期", 0, "value"],
          "default": ""
        },
        "address": {
          "mode": "path",
          "source": "Defandent",
          "path": ["住所", 0, "value"],
          "default": ""
        },
        "scope": {
          "mode": "path",
          "source": "Defandent",
          "path": ["经营范围", 0, "value"],
          "default": ""
        }
      },
      "default": "",
      "required": false,
      "editable": true,
      "description": "由多个企业字段拼接成侵权公司信息"
    },
    "[--需要替换的案由--]": {
      "mode": "path",
      "source": "logical",
      "path": ["案由", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "从 logical 中读取自动推导案由"
    },
    "[--需要替换的逻辑判断1--]": {
      "mode": "path",
      "source": "logical",
      "path": ["案由", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "模板别名：案由"
    },
    "[--需要替换的诉讼请求三--]": {
      "mode": "path",
      "source": "logical",
      "path": ["诉讼请求三", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "从 logical 中读取自动推导的第三项诉请"
    },
    "[--需要替换的逻辑判断2--]": {
      "mode": "path",
      "source": "logical",
      "path": ["诉讼请求三", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "模板别名：第三项诉请"
    },
    "[--需要替换的不正当竞争事实段--]": {
      "mode": "path",
      "source": "logical",
      "path": ["不正当竞争事实段", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "从 logical 中读取自动推导的不正当竞争事实段"
    },
    "[--需要替换的逻辑判断3--]": {
      "mode": "path",
      "source": "logical",
      "path": ["不正当竞争事实段", 0, "value"],
      "default": "",
      "required": false,
      "editable": true,
      "description": "模板别名：不正当竞争事实段"
    }
  }
}
